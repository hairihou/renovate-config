{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":timezone(Asia/Tokyo)",
    "group:definitelyTyped",
    "helpers:disableTypesNodeMajor",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "ignorePresets": [":dependencyDashboard", ":pinDevDependencies"],
  "draftPR": true,
  "lockFileMaintenance": {
    "schedule": ["on the first day of the month"]
  },
  "prConcurrentLimit": 24,
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "groupName": "linters",
      "extends": ["packages:linters"],
      "matchPackageNames": ["globals", "oxfmt"]
    },
    {
      "matchDepNames": ["ollama", "pipx:git+https://github.com/*/*.git", "python"],
      "minimumReleaseAge": "3 days",
      "schedule": ["before 8am on monday"]
    },
    {
      "matchDepNames": ["pipx:git+https://github.com/NousResearch/hermes-agent.git"],
      "fetchChangeLogs": "off"
    },
    {
      "matchPackageNames": ["pnpm"],
      "minimumReleaseAge": "0 days"
    }
  ]
}
